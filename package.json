{
  "name": "quicktodo",
  "displayName": "Quick Todo",
  "description": "Fast todo comments",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:quicktodo.add"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "quicktodo.add",
        "title": "Add Todo",
        "category": "Todo"
      }
    ],
    "keybindings": [
      {
        "command": "quicktodo.add",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}